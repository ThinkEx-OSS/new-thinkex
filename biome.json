{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/package.json",
			"**/tsconfig.json",
			"**/vite.config.ts",
			"**/vitest.config.ts",
			"**/drizzle.config.ts",
			"**/wrangler.jsonc",
			"!.reference/**/*",
			"!**/.reference/**/*",
			"!references/**/*",
			"!**/references/**/*",
			"!**/src/styles.css",
			"!!**/dist",
			"!!**/.vite",
			"!!**/*.gen.*",
			"!!**/worker-configuration.d.ts",
			"!!**/pnpm-lock.yaml"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noNestedComponentDefinitions": "error",
				"useExhaustiveDependencies": "error",
				"useHookAtTopLevel": "error",
				"useJsxKeyInIterable": "error"
			},
			"nursery": {
				"noFloatingPromises": "error",
				"noMisusedPromises": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "error",
				"noDuplicateDependencies": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/routes/**/*.{tsx,ts}"],
			"linter": {
				"rules": {
					"style": {
						"useFilenamingConvention": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
