{
	"name": "new-thinkex",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "infisical run --env=dev --path=/app -- pnpm dev:local",
		"dev:local": "vite dev --port 3000",
		"build": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false vite build",
		"preview": "pnpm run build && vite preview",
		"format": "biome format",
		"lint": "biome lint",
		"lint:types": "biome lint --only=nursery/noFloatingPromises --only=nursery/noMisusedPromises src",
		"check": "biome check",
		"lint:compiler": "eslint .",
		"analyze": "ANALYZE=true pnpm build",
		"doctor": "react-doctor . --scope changed --verbose",
		"doctor:full": "react-doctor . --scope full --verbose",
		"knip": "knip",
		"prepare": "lefthook install",
		"postinstall": "node scripts/copy-pdfium-wasm.mjs",
		"copy-pdfium-wasm": "node scripts/copy-pdfium-wasm.mjs",
		"references:setup": "bash scripts/setup-references-workspace.sh",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsgo --noEmit",
		"typecheck:tsc": "tsc --noEmit",
		"deploy": "pnpm run build && wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "infisical run --env=dev --path=/app -- pnpm db:migrate:local",
		"db:migrate:prod": "infisical run --env=prod --path=/app -- pnpm db:migrate:local",
		"db:migrate:local": "drizzle-kit migrate",
		"db:check": "drizzle-kit check",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types",
		"wrangler": "wrangler"
	},
