{
	"name": "new-thinkex",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"dev:cloudflare": "pnpm run dev",
		"dev:hyperdrive": "THINKEX_DB_DRIVER=hyperdrive wrangler dev --remote",
		"build": "vite build",
		"preview": "pnpm run build && vite preview",
		"format": "biome format",
		"lint": "biome lint",
		"lint:types": "biome lint --only=nursery/noFloatingPromises --only=nursery/noMisusedPromises src",
		"check": "biome check",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsgo --noEmit",
		"typecheck:tsc": "tsc --noEmit",
		"deploy": "THINKEX_DB_DRIVER=hyperdrive pnpm run build && wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types",
		"wrangler": "wrangler"
	},
