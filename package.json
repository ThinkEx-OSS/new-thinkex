{
	"name": "new-thinkex",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "infisical run --env=dev --path=/app -- pnpm dev:local",
		"dev:local": "vite dev --port 3000",
		"build": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false vite build",
		"preview": "pnpm run build && vite preview",
		"format": "biome format",
		"lint": "biome lint",
		"lint:types": "biome lint --only=nursery/noFloatingPromises --only=nursery/noMisusedPromises src",
		"check": "biome check",
		"lint:compiler": "eslint .",
		"analyze": "ANALYZE=true pnpm build",
		"doctor": "pnpm dlx react-doctor@0.5.6 . --scope changed --verbose",
		"doctor:full": "pnpm dlx react-doctor@0.5.6 . --scope full --verbose",
		"knip": "knip",
		"prepare": "lefthook install",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsgo --noEmit",
		"typecheck:tsc": "tsc --noEmit",
		"deploy": "pnpm run build && wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "infisical run --env=dev --path=/app -- pnpm db:migrate:local",
		"db:migrate:local": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types",
		"wrangler": "wrangler"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@cloudflare/ai-chat": "^0.8.4",
		"@cloudflare/shell": "^0.3.9",
