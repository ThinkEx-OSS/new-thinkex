		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.1",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"jsdom": "^28.1.0",
		"knip": "^6.14.2",
		"lefthook": "^2.1.8",
