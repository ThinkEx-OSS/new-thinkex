{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "new-thinkex",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": ["nodejs_compat"],
	"main": "src/server.ts",
	"observability": {
		"enabled": true
	},
	"vars": {
		"THINKEX_DB_DRIVER": "hyperdrive"
	},
	"secrets": {
		"required": [
			"BETTER_AUTH_URL",
			"BETTER_AUTH_SECRET",
			"GOOGLE_CLIENT_ID",
			"GOOGLE_CLIENT_SECRET"
		]
	},
	"upload_source_maps": true,
	"durable_objects": {
		"bindings": [
			{
				"name": "WorkspaceRoom",
				"class_name": "WorkspaceRoom"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1_workspace_room",
			"new_sqlite_classes": ["WorkspaceRoom"]
		}
	],
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "5bed5fff754c4a50b8d3338db761d88e"
		}
	]
}
